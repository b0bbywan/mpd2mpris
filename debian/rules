#!/usr/bin/make -f
export PYBUILD_NAME=mpdris2

%:
	dh $@ --with python3 --buildsystem=pybuild

# Compile gettext catalogs into mpdris2/locale/ so setuptools picks
# them up via package_data. Babel ships .py extractors only, so we
# use plain msgfmt here.
override_dh_auto_build:
	@for po in po/*.po; do \
		lang=$$(basename $$po .po); \
		mkdir -p mpdris2/locale/$$lang/LC_MESSAGES; \
		msgfmt $$po -o mpdris2/locale/$$lang/LC_MESSAGES/mpdris2.mo; \
	done
	dh_auto_build

# Tests run in the CI lint job (pytest + dbus_fast in a venv); the deb
# build env has neither, and shipping pytest into it for this is silly.
override_dh_auto_test:

override_dh_installsystemduser:
	dh_installsystemduser --no-enable
